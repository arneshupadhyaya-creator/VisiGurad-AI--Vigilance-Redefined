# -----------------------------------------------------------------------------
# VisiGuard AI - Backend Environment Configuration Example
# Copy this file to '.env' and populate with actual credentials
# -----------------------------------------------------------------------------

# Web Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (MongoDB)
# Set to your local MongoDB server or a remote MongoDB Atlas connection URI
MONGO_URI=mongodb://127.0.0.1:27017/visiguard

# JWT Security
# Replace with a long, random, secure key in production (e.g., 'openssl rand -base64 32')
JWT_SECRET=DUMMY_REPLACE_WITH_REAL_SECRET
JWT_EXPIRES_IN=24h

# Pluggable AI Service Configuration (Future local model API)
AI_MODEL_ENDPOINT=http://localhost:8000/predict

# Redis Configuration (Future job queueing BullMQ)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
